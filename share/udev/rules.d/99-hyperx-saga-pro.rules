# HyperX Pulsefire Saga Pro hidraw access for Linux userspace control.
# This rule is intentionally limited to the Saga Pro wired and 2.4 GHz PIDs.
# The previous uaccess-only rule did not apply ACLs reliably on some Bazzite/Fedora systems.

# Wired USB mode: 03f0:04bf
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="03f0", ATTRS{idProduct}=="04bf", MODE:="0666", TAG+="uaccess"
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ENV{ID_VENDOR_ID}=="03f0", ENV{ID_MODEL_ID}=="04bf", MODE:="0666", TAG+="uaccess"

# 2.4 GHz wireless dongle mode: 03f0:06bf
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="03f0", ATTRS{idProduct}=="06bf", MODE:="0666", TAG+="uaccess"
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ENV{ID_VENDOR_ID}=="03f0", ENV{ID_MODEL_ID}=="06bf", MODE:="0666", TAG+="uaccess"
