#!/usr/bin/env bash
set -euo pipefail

APP_DIR="${HYPERX_SAGA_CONTROL_APP_DIR:-$HOME/.local/share/hyperx-saga-control}"
PYTHON_BIN="${APP_DIR}/.venv/bin/python"

if [[ ! -x "$PYTHON_BIN" ]]; then
  PYTHON_BIN="$(command -v python3)"
fi

export PYTHONPATH="$APP_DIR${PYTHONPATH:+:$PYTHONPATH}"
exec "$PYTHON_BIN" -m hyperx_saga_control "$@"
